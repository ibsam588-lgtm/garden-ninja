default_platform(:android)

platform :android do
  desc "Upload Garden Ninja to the Google Play internal testing track"
  lane :internal do
    upload_to_play_store(
      package_name: ENV.fetch("ANDROID_PACKAGE_NAME", "com.gardenninja.garden_ninja"),
      track: ENV.fetch("PLAY_TRACK", "internal"),
      release_status: "completed",
      aab: File.expand_path("../build/app/outputs/bundle/release/app-release.aab", __dir__),
      json_key: File.expand_path("play-store-service-account.json", __dir__),
      metadata_path: File.expand_path("metadata/android", __dir__)
    )
  end
end
